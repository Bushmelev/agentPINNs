    "activation": "tanh"
  },
  "training": {
    "steps": 10000,
    "full_batch": true,
    "batch_sizes": {},
    "pool_sizes": {},
    "optimizer_mode": "adam",
    "optimizer": "adamw",
    "lr": 0.01,
    "weight_decay": 0.0001,
    "scheduler": "cosine",
    "scheduler_kwargs": {
      "t_max": 10000,
      "eta_min": 1e-05
    },
    "adam_steps": 10000,
    "lbfgs_steps": 0,
    "lbfgs_lr": 1.0,
    "lbfgs_max_iter": 1,
    "lbfgs_max_eval": null,
    "lbfgs_history_size": 20,

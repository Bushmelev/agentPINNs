{
  "equation": "burgers",
  "equation_params": {
    "nu": 0.001,
    "data_path": "../hdf5-files/1D_Burgers_one_harmonic.hdf5",
    "sample_id": 0,
    "target_time": 0.0
  },
  "controllers": [
    "fixed"
  ],
  "seed": 1234,
  "device": "auto",
  "output_dir": "artifacts/fixed_cosine_scheduler",
  "save_plots": true,
  "plot_grid": 120,
  "solution_slice_times": [
    0.5,
    1.0,
    1.5,
    2.0
  ],
  "model": {
    "layers": [
      2,
      40,
      40,
      40,
      40,
      1

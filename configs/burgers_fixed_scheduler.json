      "include_initial_loss_ratios": true,
      "policy_bias": false,
      "policy_hidden_dim": null,
      "zero_init_policy": true
    },
    "softadapt": {
      "temperature": 1.0
    },
    "relobralo": {
      "alpha": 0.999,
      "beta": 0.99,
      "tau": 1.0
    },
    "gradnorm": {
      "alpha": 1.0

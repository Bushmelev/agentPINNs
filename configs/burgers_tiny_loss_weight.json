{
  "equation": "burgers",
  "equation_params": {},
  "controllers": ["fixed", "tiny_loss_weight", "softadapt", "relobralo", "gradnorm"],
  "seed": 1234,
  "device": "auto",
  "output_dir": "artifacts",
  "save_plots": true,
  "plot_grid": 120,
  "model": {
    "layers": [2, 40, 40, 40, 40, 1],
    "activation": "tanh"
  },
  "training": {
    "steps": 8000,
    "batch_sizes": {
      "pde": 4096,
      "ic": 512,
      "bc": 512
    },
    "pool_sizes": {
      "pde": 65536,
      "ic": 8192,
      "bc": 8192
    },
    "optimizer_mode": "adam",
    "optimizer": "adam",
    "lr": 0.001,
    "weight_decay": 0.0,
    "scheduler": "constant",
    "adam_steps": null,
    "lbfgs_steps": null,
    "lbfgs_lr": 1.0,
    "lbfgs_max_iter": 20,
    "lbfgs_max_eval": null,
    "lbfgs_history_size": 100,
    "lbfgs_tolerance_grad": 1e-7,
    "lbfgs_tolerance_change": 1e-9,
    "lbfgs_line_search_fn": "strong_wolfe",
    "log_every": 100,
    "agent_update_interval": 25,
    "agent_warmup_steps": 0,
    "compile_model": false
  },
  "controller_params": {
    "tiny_loss_weight": {
      "reward": "baseline_gap",
      "sigma": 0.1,
      "action_scale": 0.1,
      "min_weight_share": 0.1,
      "max_weight_share": 0.6,
      "include_initial_loss_ratios": true,
      "zero_init_policy": true
    },
    "softadapt": {
      "temperature": 1.0
    },
    "relobralo": {
      "alpha": 0.999,
      "beta": 0.99,
      "tau": 1.0
    },
    "gradnorm": {
      "alpha": 1.0
    }
  }
}

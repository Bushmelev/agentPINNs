{
  "equation": "burgers",
  "equation_params": {},
  "controllers": ["fixed", "tiny_loss_weight"],
  "seed": 1234,
  "device": "auto",
  "output_dir": "artifacts",
  "save_plots": true,
  "plot_grid": 120,
  "model": {
    "layers": [2, 40, 40, 40, 40, 1],
    "activation": "tanh"
  },
  "training": {
    "steps": 2000,
    "batch_sizes": {
      "pde": 4096,
      "ic": 512,
      "bc": 512
    },
    "pool_sizes": {
      "pde": 65536,
      "ic": 8192,
      "bc": 8192
    },
    "optimizer": "adam",
    "lr": 0.001,
    "weight_decay": 0.0,
    "scheduler": "constant",
    "log_every": 100,
    "agent_update_interval": 25,
    "agent_warmup_steps": 250,
    "compile_model": false
  },
  "controller_params": {
    "tiny_loss_weight": {
      "reward": "baseline_gap",
      "sigma": 0.1,
      "action_scale": 0.1,
      "min_weight_share": 0.1,
      "max_weight_share": 0.6,
      "include_initial_loss_ratios": true,
      "zero_init_policy": true
    }
  }
}
